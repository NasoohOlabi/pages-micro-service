VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_APP_ID=your-firebase-web-app-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_SHEET_ID=your-spreadsheet-id
# Data range only — exclude the header row (e.g. row 1 has headers, data starts at row 2)
VITE_SHEET_RANGE=Sheet1!A2:D
VITE_POINTS_SHEET_RANGE=Points!A2:E
VITE_ATTENDANCE_SHEET_ID=your-attendance-spreadsheet-id
VITE_ATTENDANCE_SHEET_NAME=AutoAttendance

# Separate spreadsheet holding the student roster, used for fuzzy student-name search
VITE_ROSTER_SHEET_ID=your-roster-spreadsheet-id
# gid of the roster tab (from the sheet URL's #gid=... fragment)
VITE_ROSTER_GID=0
# Column letter in the roster tab that holds the student's full name
VITE_ROSTER_NAME_COLUMN=A

# Spreadsheet ID holding the Teachers tab
VITE_TEACHERS_SHEET_ID=your-teachers-spreadsheet-id
# Tab name (in VITE_TEACHERS_SHEET_ID) listing teachers
VITE_TEACHERS_SHEET_NAME=Teachers Sheet
# Column letter in the teachers tab that holds the teacher's full name
VITE_TEACHERS_NAME_COLUMN=A
# Column letter in the teachers tab that holds the teacher's email
VITE_TEACHERS_EMAIL_COLUMN=B
